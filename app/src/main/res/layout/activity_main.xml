<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F5F7FA"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PCHcheck"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/search_bg"
            app:queryHint="Search parts..."
            app:iconifiedByDefault="false"
            app:queryBackground="@android:color/transparent" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">

            <EditText
                android:id="@+id/etMinPrice"
                android:layout_width="90dp"
                android:layout_height="44dp"
                android:hint="Min $"
                android:textColor="#555555"
                android:textColorHint="#888888"
                android:background="@drawable/filter_input_bg"
                android:paddingHorizontal="12dp"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etMaxPrice"
                android:layout_width="90dp"
                android:layout_height="44dp"
                android:hint="Max $"
                android:textColor="#555555"
                android:textColorHint="#888888"
                android:background="@drawable/filter_input_bg"
                android:paddingHorizontal="12dp"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:layout_marginEnd="16dp"/>

            <CheckBox
                android:id="@+id/cbAmazon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amazon"
                android:textColor="#555555"
                android:checked="true"
                android:buttonTint="#555555" />

            <CheckBox
                android:id="@+id/cbMicroCenter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Micro Center"
                android:textColor="#555555"
                android:checked="true"
                android:buttonTint="#555555" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHardware"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/filterScroll"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#F5F7FA"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSupport"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Logout"
            android:backgroundTint="#FF5252"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>